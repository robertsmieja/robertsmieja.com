---
import { faPrint } from "@fortawesome/free-solid-svg-icons"
import Icon from "../components/Icon.astro"
import DevOps from "../components/resume/DevOps.astro"
import Education from "../components/resume/Education.astro"
import Experience from "../components/resume/Experience.astro"
import Profile from "../components/resume/Profile.astro"
import Technology from "../components/resume/Technology.astro"
import Layout from "../layouts/Layout.astro"
---

<Layout
  title="R\u00e9sum\u00e9"
  keywords={[
    "back",
    "backend",
    "developer",
    "devops",
    "engineer",
    "full",
    "fullstack",
    "robertsmieja",
    "robert",
    "smieja",
    "stack",
    "resume",
    "r\u00e9sum\u00e9",
    "software",
    "wpi",
    "worcester",
    "polytechnic",
    "institute",
  ]}
>
  <div class="resume-container">
    <div class="header-container">
      <h1>Robert Smieja</h1>
      <h4>Polyglot Full-stack Software Engineer</h4>
      <button
        type="button"
        class="print-button"
        onclick="window.print()"
        aria-label="Print Resume"
        title="Print Resume"
      >
        <Icon icon={faPrint} />
      </button>
    </div>
    <div class="grid-container">
      <Experience />
      <Profile />
      <Technology />
      <DevOps />
      <Education />
    </div>
  </div>
</Layout>

<style>
  .resume-container {
    max-width: 8.5in;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media print {
    .resume-container {
      max-width: 100%;
      padding: 0;
      margin: 0;
    }
  }

  .header-container {
    text-align: center;
    position: relative;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #222;
    margin-bottom: 0.25rem;
  }

  .header-container h1 {
    margin: 0.5rem 0 0.25rem;
    font-size: 2.25rem;
    letter-spacing: 0.02em;
  }

  .header-container h4 {
    margin: 0 0 0.25rem;
    font-weight: 400;
    color: #444;
    font-size: 1.1rem;
  }

  @media print {
    .header-container {
      border-bottom: 1.5px solid #222;
      margin-bottom: 0.3rem;
      padding-bottom: 0.3rem;
    }

    .header-container h1 {
      margin: 0.2rem 0;
      font-size: 1.8rem;
    }

    .header-container h4 {
      margin: 0.1rem 0;
      font-size: 1.1rem;
    }
  }

  .print-button {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    padding: 0.5rem;
    color: inherit;
    z-index: 100;
  }

  .print-button:hover,
  .print-button:focus-visible {
    opacity: 0.7;
  }

  @media print {
    .print-button {
      display: none;
    }
  }

  .grid-container {
    text-align: left;
  }

  .grid-container :global(h2) {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1.5px solid #444;
    padding-bottom: 0.2rem;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .grid-container :global(dl) {
    margin: 0 0 0.5rem 0;
  }

  .grid-container :global(dt) {
    font-weight: 600;
    font-size: 0.85rem;
    color: #555;
    margin-bottom: 0.1rem;
  }

  .grid-container :global(dd) {
    margin-left: 0;
    margin-bottom: 0.4rem;
  }

  @media print {
    .grid-container {
      display: block;
    }

    .grid-container :global(h2) {
      margin: 0.3rem 0 0.15rem 0;
      font-size: 0.9rem;
      border-bottom: 1px solid #ccc;
      padding-bottom: 0.1rem;
      letter-spacing: 0.05em;
    }

    .grid-container :global(dl),
    .grid-container :global(ul) {
      margin-top: 0;
      margin-bottom: 0.1rem;
    }

    .grid-container :global(li) {
      margin-bottom: 0;
    }
  }
</style>
