---
import { getCollection } from "astro:content"
import { sortBlogPosts } from "../../lib/blogUtils.ts"
import Layout from "../../layouts/Layout.astro"

const posts = sortBlogPosts(await getCollection("blog"))
---

<Layout
  title="Blog"
  keywords={["blog", "technology", "software engineering", "robertsmieja"]}
>
  <div>
    <h4>Blog</h4>
    <p>
      Thoughts on technology, software engineering, and things I find
      interesting.{" "}
      <a href="/rss.xml" class="rss-link">RSS Feed</a>
    </p>
    {
      posts.length === 0 ? (
        <p>No blog posts yet. Check back soon!</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => {
            const title = post.data.title || post.slug
            const formattedDate = new Date(post.data.date).toLocaleDateString(
              "en-US",
              {
                year: "numeric",
                month: "long",
                day: "numeric",
              }
            )
            return (
              <li class="post-item">
                <h3 class="post-title">
                  <a href={`/blog/${post.slug}/`}>{title}</a>
                </h3>
                <time class="post-date" datetime={post.data.date}>
                  {formattedDate}
                </time>
                <p>{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <ul class="tag-list">
                    {post.data.tags.map((tag) => (
                      <li class="tag">{tag}</li>
                    ))}
                  </ul>
                )}
              </li>
            )
          })}
        </ul>
      )
    }
  </div>
</Layout>

<style>
  .rss-link {
    font-size: 0.9rem;
    color: #666;
  }

  .post-list {
    max-width: 48rem;
    list-style: none;
    padding: 0;
  }

  .post-item {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #eee;
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-title {
    margin: 0 0 0.25rem 0;
  }

  .post-title a {
    color: black;
    text-decoration: none;
  }

  .post-title a:hover,
  .post-title a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .post-date {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    display: block;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #f0f0f0;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #555;
  }
</style>
