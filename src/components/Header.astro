---
import { faGithub, faLinkedin } from "@fortawesome/free-brands-svg-icons"
import Icon from "./Icon.astro"

interface Props {
  siteTitle: string
}

const { siteTitle } = Astro.props
const pathname = Astro.url.pathname
---

<header>
  <nav role="navigation">
    <ul>
      <li>
        <a href="/">
          <h2>{siteTitle}</h2>
        </a>
      </li>
      <li>
        <a
          href="/"
          class:list={[{ active: pathname === "/" }]}
          aria-current={pathname === "/" ? "page" : undefined}>Home</a
        >
      </li>
      <li>
        <a
          href="/blog/"
          class:list={[{ active: pathname.startsWith("/blog/") }]}
          aria-current={pathname.startsWith("/blog/") ? "page" : undefined}
        >
          Blog
        </a>
      </li>
      <li>
        <a
          href="/presentations/"
          class:list={[{ active: pathname === "/presentations/" }]}
          aria-current={pathname === "/presentations/" ? "page" : undefined}
        >
          Presentations
        </a>
      </li>
      <li>
        <a
          href="/projects/"
          class:list={[{ active: pathname === "/projects/" }]}
          aria-current={pathname === "/projects/" ? "page" : undefined}
        >
          Projects
        </a>
      </li>
      <li>
        <a
          href="/resume/"
          class:list={[{ active: pathname === "/resume/" }]}
          aria-current={pathname === "/resume/" ? "page" : undefined}
        >
          R&eacute;sum&eacute;
        </a>
      </li>
      <li class="github-li">
        <a
          href="https://github.com/robertsmieja/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Robert Smieja's GitHub Profile"
        >
          <Icon icon={faGithub} /> GitHub
        </a>
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/robertsmieja/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Robert Smieja's LinkedIn Profile"
        >
          <Icon icon={faLinkedin} /> LinkedIn
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  header {
    width: 100%;
    grid-column: 1 / 4;
    padding: 1rem;
  }

  header::after {
    content: "";
    display: block;
    clear: both;
  }

  @media print {
    header {
      display: none;
    }
  }

  nav {
    border-bottom: 1px solid black;
    transition: width 600ms ease;
  }

  ul {
    flex-direction: row;
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }

  li {
    float: left;
    margin: 0.5rem 0.5rem;
  }

  .github-li {
    margin-left: auto;
  }

  a {
    color: black;
    text-decoration: none;
  }

  a:hover,
  a:focus-visible,
  a.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  a:focus-visible {
    outline: 2px solid black;
    outline-offset: 2px;
  }

  a.active {
    font-weight: bold;
  }
</style>
