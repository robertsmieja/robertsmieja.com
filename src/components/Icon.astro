---
import type { IconDefinition } from "@fortawesome/fontawesome-svg-core"
import { icon as faIcon } from "@fortawesome/fontawesome-svg-core"

interface Props {
  icon: IconDefinition
  class?: string
}

const { icon, class: className } = Astro.props
const rendered = faIcon(icon)
const svgHtml = rendered.html[0]
---

<span class:list={["fa-icon", className]} set:html={svgHtml} />

<style>
  .fa-icon {
    display: inline-block;
    height: 1em;
    vertical-align: -0.125em;
  }
  .fa-icon :global(svg) {
    height: 1em;
    width: auto;
    fill: currentColor;
  }
</style>
