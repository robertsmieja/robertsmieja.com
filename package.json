{
  "name": "robertsmieja.com",
  "private": true,
  "description": "Robert Smieja's personal website",
  "version": "0.1.0",
  "author": "Robert Smieja <robertsmieja@robertsmieja.com>",
  "type": "module",
  "dependencies": {
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@csstools/normalize.css": "^12.1.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "astro": "^5.0.0",
    "rehype-autolink-headings": "^7.0.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "remark-smartypants": "^3.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "keywords": [
    "astro",
    "robert",
    "robertsmieja",
    "smieja"
  ],
  "license": "MIT",
  "scripts": {
    "build": "astro build",
    "check": "run-p type-check lint format",
    "clean": "rimraf dist/",
    "dev": "astro dev",
    "develop": "astro dev",
    "format": "prettier --write \"src/**/*.{astro,js,jsx,ts,tsx,md,json}\" \"*.{js,mjs,json,md}\"",
    "lint": "eslint \"src/**/*.{astro,js,jsx,ts,tsx}\"",
    "preinstall": "npx only-allow pnpm",
    "preview": "astro preview",
    "start": "astro dev",
    "serve": "astro preview",
    "type-check": "astro check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robertsmieja/robertsmieja.com"
  },
  "bugs": {
    "url": "https://github.com/robertsmieja/robertsmieja.com/issues"
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": [
        "lint-staged"
      ],
      "post-merge": [
        "post-npm-install"
      ],
      "post-rebase": [
        "post-npm-install"
      ]
    }
  }
}
